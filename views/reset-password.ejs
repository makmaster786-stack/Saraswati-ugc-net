<% /* --- FILE: views/reset-password.ejs (CORRECTED) --- */ %>
<%- include('partials/header-professional', { 
    title: 'Reset Password - Saraswati UGC NET',
    user: user,
    script: '/js/auth.js' 
}) %>

<main class="auth-page">
    <section class="auth-section">
        <div class="auth-container">
            <div class="auth-form-container">
                <div class="auth-header">
                    <h1>Reset Your Password</h1>
                    <p>Enter your new password below.</p>
                </div>
                
                <form id="resetPasswordForm" class="auth-form">
                    <div class="form-group">
                        <label for="newPassword" class="form-label">
                            <i class="fas fa-lock"></i> New Password
                        </label>
                        <input type="password" id="newPassword" class="form-input" required placeholder="Enter your new password">
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg btn-block">Reset Password</button>
                </form>

                <div class="auth-footer">
                    <p>Remember your password? <a href="/login" class="auth-link">Back to login</a></p>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer-professional') %>