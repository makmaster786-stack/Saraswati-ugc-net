<%- include('partials/header-professional', { title: '404 — Page Not Found' }) %>

<style>
.notfound-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1rem;
    background: var(--bg-secondary, #f8fafc);
}
.notfound-card {
    text-align: center;
    max-width: 520px;
    width: 100%;
    background: white;
    border-radius: 24px;
    padding: 3rem 2.5rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    border: 1px solid #e2e8f0;
}
.notfound-code {
    font-size: 7rem;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, #0ea5e9, #6366f1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
    letter-spacing: -4px;
}
.notfound-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
}
.notfound-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
}
.notfound-desc {
    font-size: 0.95rem;
    color: #64748b;
    line-height: 1.7;
    margin: 0 0 2rem;
}
.notfound-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
}
.btn-home {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: linear-gradient(135deg, #0ea5e9, #6366f1);
    color: white;
    padding: 0.7rem 1.5rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 12px rgba(14,165,233,0.3);
}
.btn-home:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(14,165,233,0.4);
    color: white;
}
.btn-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: white;
    color: #334155;
    padding: 0.7rem 1.5rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    border: 1.5px solid #e2e8f0;
    transition: all 0.15s;
}
.btn-back:hover {
    background: #f8fafc;
    border-color: #94a3b8;
    color: #0f172a;
}
.notfound-links {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #f1f5f9;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
}
.notfound-links a {
    font-size: 0.84rem;
    color: #0ea5e9;
    font-weight: 600;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.3rem;
}
.notfound-links a:hover { text-decoration: underline; }
</style>

<main class="notfound-page">
    <div class="notfound-card">
        <div class="notfound-code">404</div>
        <div class="notfound-icon">🎓</div>
        <h1 class="notfound-title">Page Not Found</h1>
        <p class="notfound-desc">
            Looks like this page went on study leave.<br>
            The link may be broken or the page may have moved.
        </p>
        <div class="notfound-actions">
            <a href="/" class="btn-home">
                <i class="fas fa-home"></i> Go to Homepage
            </a>
            <a href="javascript:history.back()" class="btn-back">
                <i class="fas fa-arrow-left"></i> Go Back
            </a>
        </div>
        <div class="notfound-links">
            <a href="/courses"><i class="fas fa-book-open"></i> Courses</a>
            <a href="/available-tests"><i class="fas fa-file-alt"></i> Mock Tests</a>
            <a href="/knowledge-base"><i class="fas fa-lightbulb"></i> Study Material</a>
            <a href="/contact"><i class="fas fa-envelope"></i> Contact</a>
        </div>
    </div>
</main>

<%- include('partials/footer-professional') %>
