<%- include('partials/header-professional', { title: 'Mock Test', script: '/js/test-interface.js' }) %>

<style>
/* ══════════════════════════════════════════
   NTA-STYLE EXAM INTERFACE — COMPLETE
   saraswati-ugcnet / take-test.ejs
══════════════════════════════════════════ */

/* Override body for full-screen test mode */
body { background: #f0f2f5 !important; overflow: hidden; }
.navbar, .navbar-pro, footer, .page-hero { display: none !important; }
main { padding: 0 !important; margin: 0 !important; }

/* ── ROOT LAYOUT ── */
.test-interface-fullscreen {
  height: 100vh; height: 100dvh;
  display: flex; flex-direction: column; overflow: hidden;
  font-family: var(--font-body); background: #f0f2f5;
}

/* ── TOP HEADER ── */
.test-header-pro {
  background: linear-gradient(135deg, #0c4a6e 0%, #0369a1 100%);
  padding: 0 1.25rem; height: 58px; display: flex; align-items: center;
  flex-shrink: 0; box-shadow: 0 2px 8px rgba(0,0,0,0.2); z-index: 100;
}
.test-header-content {
  width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
}
.test-info { display: flex; align-items: center; gap: 1rem; min-width: 0; }
.test-logo { width: 32px; height: 32px; border-radius: 8px; background: white; padding: 3px; flex-shrink: 0; }
#test-title { 
  font-family: var(--font-heading); 
  font-size: 0.95rem;
  font-weight: 700; 
  color: #1e293b !important; /* FIX: Changed to dark text so it shows on white */
  white-space: nowrap; 
  overflow: hidden; 
  text-overflow: ellipsis; 
  flex: 1; 
  min-width: 50px;
}
.test-meta-badges { display: flex; gap: 0.5rem; }
.test-meta-badge {
  font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 20px;
  background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.9); white-space: nowrap;
}
.test-meta-badge.diff-easy { background: rgba(16,185,129,0.3); }
.test-meta-badge.diff-medium { background: rgba(245,158,11,0.3); }
.test-meta-badge.diff-hard { background: rgba(239,68,68,0.3); }

/* Timer */
.test-controls { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }
.timer-box {
  display: flex; align-items: center; gap: 0.5rem;
  background: #f1f5f9 !important; 
  border: 1px solid #cbd5e1 !important;
  border-radius: 10px; padding: 0.45rem 0.9rem;
}
.timer-box i { color: #64748b !important; font-size: 0.85rem; }
#test-timer {
  font-family: 'Courier New', monospace;
  font-size: 1.1rem; font-weight: 700;
  color: #0f172a !important; /* Dark text for timer */
  letter-spacing: 0.05em; min-width: 72px; text-align: center;
}
.timer-box.warning { background: rgba(245,158,11,0.3); border-color: rgba(245,158,11,0.5); }
.timer-box.danger { background: rgba(239,68,68,0.4); border-color: rgba(239,68,68,0.6); animation: timerPulse 1s infinite; }
@keyframes timerPulse { 0%,100%{opacity:1} 50%{opacity:0.7} }

.btn-header {
  display: flex;
  align-items: center; gap: 0.4rem; padding: 0.4rem 0.8rem;
  border-radius: 8px; 
  border: 1px solid #cbd5e1 !important; /* FIX: Visible border */
  background: #f8fafc !important;       /* FIX: Light gray background */
  color: #475569 !important;            /* FIX: Dark gray text/icons */
  font-size: 0.78rem;
  font-weight: 600; cursor: pointer; transition: all 0.2s;
  font-family: var(--font-heading); white-space: nowrap;
}
.btn-header:hover { 
  background: #e2e8f0 !important; 
  color: #0f172a !important; 
}
/* ── BODY LAYOUT ── */
.test-body { flex: 1; display: flex; overflow: hidden; min-height: 0; }

/* ── QUESTION PANEL ── */
.question-panel-pro {
  flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0;
  background: white; border-right: 1px solid #e2e8f0;
}

/* Question Panel Header — section tabs + lang toggle */
.question-panel-header {
  display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
  padding: 0.65rem 1.25rem; background: #f8fafc; border-bottom: 1px solid #e2e8f0;
  flex-shrink: 0; flex-wrap: wrap;
}
.section-tabs { display: flex; gap: 0.35rem; }
.section-tab {
  padding: 0.4rem 1rem; border-radius: 8px; border: 1.5px solid #e2e8f0;
  background: white; font-family: var(--font-heading); font-size: 0.78rem; font-weight: 700;
  color: var(--gray-500); cursor: pointer; transition: all 0.2s;
}
.section-tab.active { background: var(--brand-blue); color: white; border-color: var(--brand-blue); }
.panel-actions { display: flex; gap: 0.5rem; align-items: center; }
.btn-panel {
  display: flex; align-items: center; gap: 0.4rem; padding: 0.38rem 0.8rem;
  border-radius: 8px; border: 1.5px solid #e2e8f0; background: white;
  font-family: var(--font-heading); font-size: 0.75rem; font-weight: 700;
  color: var(--gray-600); cursor: pointer; transition: all 0.2s;
}
.btn-panel:hover { border-color: var(--brand-blue); color: var(--brand-blue); }
.btn-panel.lang-active { background: rgba(14,165,233,0.08); border-color: var(--brand-blue); color: var(--brand-blue); }

/* Question counter strip */
.question-counter-strip {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.6rem 1.25rem; background: white; border-bottom: 1px solid #f1f5f9;
  flex-shrink: 0;
}
.q-counter-label {
  font-family: var(--font-heading); font-size: 0.82rem; font-weight: 700; color: var(--gray-600);
  display: flex; align-items: center; gap: 0.5rem;
}
.q-counter-label span { color: var(--brand-blue); font-size: 1rem; }
.q-status-badge {
  font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.65rem; border-radius: 20px;
  display: flex; align-items: center; gap: 0.35rem;
}
.q-status-badge.not-visited { background: #f1f5f9; color: var(--gray-500); }
.q-status-badge.not-answered { background: #fee2e2; color: #b91c1c; }
.q-status-badge.answered { background: #dcfce7; color: #15803d; }
.q-status-badge.marked-for-review { background: #fef3c7; color: #92400e; }
.q-status-badge.answered-review { background: #e0e7ff; color: #3730a3; }
.q-nav-arrows { display: flex; gap: 0.4rem; }
.btn-q-nav {
  width: 30px; height: 30px; border-radius: 7px; border: 1.5px solid #e2e8f0;
  background: white; color: var(--gray-500); cursor: pointer; font-size: 0.75rem;
  display: flex; align-items: center; justify-content: center; transition: all 0.2s;
}
.btn-q-nav:hover:not(:disabled) { border-color: var(--brand-blue); color: var(--brand-blue); }
.btn-q-nav:disabled { opacity: 0.3; cursor: not-allowed; }

/* Question Content */
.question-content-pro {
  flex: 1; overflow-y: auto; padding: 1.25rem 1.5rem 5rem;
  -webkit-overflow-scrolling: touch;
}
.question-text {
  font-size: 0.97rem; color: var(--gray-900); line-height: 1.75;
  margin-bottom: 1.5rem; font-weight: 500; user-select: none;
}
.question-text img { max-width: 100%; border-radius: 8px; margin: 0.5rem 0; }

/* Options */
.options-container { display: flex; flex-direction: column; gap: 0.7rem; }
.option-item {
  display: flex; align-items: flex-start; gap: 0.85rem;
  padding: 0.85rem 1rem; border: 2px solid #e2e8f0; border-radius: 12px;
  cursor: pointer; transition: all 0.15s; user-select: none; background: white;
}
.option-item:hover { border-color: var(--brand-blue); background: rgba(14,165,233,0.03); }
.option-item.selected { border-color: var(--brand-blue); background: rgba(14,165,233,0.06); }
.option-item input[type="radio"] { display: none; }
.option-label-key {
  width: 28px; height: 28px; border-radius: 50%; border: 2px solid #e2e8f0;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-heading); font-size: 0.78rem; font-weight: 700;
  color: var(--gray-500); flex-shrink: 0; transition: all 0.15s; margin-top: 1px;
}
.option-item.selected .option-label-key { background: var(--brand-blue); border-color: var(--brand-blue); color: white; }
.option-text { font-size: 0.9rem; color: var(--gray-800); line-height: 1.6; }

/* ── FOOTER ACTIONS ── */
.question-footer-pro {
  position: fixed; bottom: 0; left: 0; right: 340px; /* sidebar width */
  background: white; border-top: 2px solid #e2e8f0;
  padding: 0.75rem 1.25rem; display: flex; gap: 0.6rem; align-items: center;
  z-index: 50; flex-wrap: wrap;
  padding-bottom: calc(0.75rem + env(safe-area-inset-bottom));
}
.btn-action {
  display: flex; align-items: center; gap: 0.4rem; padding: 0.6rem 1.1rem;
  border-radius: 10px; font-family: var(--font-heading); font-size: 0.82rem;
  font-weight: 700; cursor: pointer; transition: all 0.2s; border: none; white-space: nowrap;
}
.btn-action:disabled { opacity: 0.6; cursor: not-allowed; }
.btn-save-next { background: var(--brand-blue); color: white; }
.btn-save-next:hover:not(:disabled) { background: var(--brand-blue-d); transform: translateY(-1px); }
.btn-save-review { background: #7c3aed; color: white; }
.btn-save-review:hover:not(:disabled) { background: #6d28d9; }
.btn-mark-review { background: white; color: #7c3aed; border: 2px solid #7c3aed !important; }
.btn-mark-review:hover { background: #f5f3ff; }
.btn-clear { background: white; color: #ef4444; border: 2px solid #fecaca !important; }
.btn-clear:hover { background: #fef2f2; border-color: #ef4444 !important; }
.btn-action.btn-sm { padding: 0.5rem 0.8rem; font-size: 0.75rem; }
.footer-spacer { flex: 1; }

/* ── SIDEBAR PANEL ── */
.sidebar-panel {
  width: 340px; flex-shrink: 0; display: flex; flex-direction: column;
  background: #f8fafc; border-left: 1px solid #e2e8f0;
  overflow-y: auto; overflow-x: hidden;
  min-height: 0; /* required for overflow-y:auto to work inside a flex container */
}

/* User card at top of sidebar */
.sidebar-user-card {
  display: flex; align-items: center; gap: 0.85rem; padding: 1rem 1.25rem;
  background: white; border-bottom: 1px solid #e2e8f0;
}
.sidebar-avatar {
  width: 42px; height: 42px; border-radius: 50%; object-fit: cover;
  border: 2px solid rgba(14,165,233,0.3); flex-shrink: 0;
}
.sidebar-user-name { font-family: var(--font-heading); font-size: 0.88rem; font-weight: 700; color: var(--gray-800); }
.sidebar-user-role { font-size: 0.74rem; color: var(--gray-400); }

/* Stats strip in sidebar */
.sidebar-stats {
  display: grid; grid-template-columns: repeat(4, 1fr);
  border-bottom: 1px solid #e2e8f0; background: white;
}
.sidebar-stat {
  display: flex; flex-direction: column; align-items: center; padding: 0.6rem 0.25rem;
  border-right: 1px solid #f1f5f9; font-size: 0.7rem; color: var(--gray-500); gap: 0.15rem;
}
.sidebar-stat:last-child { border-right: none; }
.sidebar-stat strong { font-family: var(--font-heading); font-size: 1rem; font-weight: 800; }
.sidebar-stat.s-answered strong { color: #16a34a; }
.sidebar-stat.s-not-ans strong { color: #dc2626; }
.sidebar-stat.s-marked strong { color: #d97706; }
.sidebar-stat.s-not-vis strong { color: var(--gray-400); }

/* Palette legend */
.palette-section { padding: 0.75rem 1rem 0.5rem; }
.palette-title { font-family: var(--font-heading); font-size: 0.74rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: var(--gray-400); margin-bottom: 0.6rem; }
.palette-legend { display: grid; grid-template-columns: 1fr 1fr; gap: 0.3rem; margin-bottom: 0.75rem; }
.legend-row { display: flex; align-items: center; gap: 0.45rem; font-size: 0.72rem; color: var(--gray-600); }
.legend-dot {
  width: 14px; height: 14px; border-radius: 3px; flex-shrink: 0;
}
.legend-dot.answered { background: #16a34a; }
.legend-dot.not-answered { background: #dc2626; }
.legend-dot.marked-for-review { background: #d97706; }
.legend-dot.answered-review { background: #7c3aed; }
.legend-dot.not-visited { background: #e2e8f0; border: 1px solid #cbd5e1; }

/* Palette Grid */
.palette-grid-wrap { padding: 0 1rem 0.75rem; }
.question-palette-grid {
  display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.5rem;
}
.palette-btn {
  aspect-ratio: 1; border-radius: 6px; border: none; font-family: var(--font-heading);
  font-size: 0.72rem; font-weight: 700; cursor: pointer; transition: all 0.15s;
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
.palette-btn.not-visited { background: #f1f5f9; color: var(--gray-500); border: 1px solid #e2e8f0; }
.palette-btn.not-answered { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }
.palette-btn.answered { background: #dcfce7; color: #15803d; border: 1px solid #86efac; }
.palette-btn.marked-for-review { background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; }
.palette-btn.answered-review { background: #ede9fe; color: #5b21b6; border: 1px solid #c4b5fd; }
.palette-btn.current {
  outline: 3px solid var(--brand-blue); outline-offset: 1px;
  transform: scale(1.1); z-index: 1;
}
.palette-btn:hover { transform: scale(1.12); z-index: 2; }

/* Submit button in sidebar */
.sidebar-submit-area { padding: 0.75rem 1rem; margin-top: auto; }
.btn-submit-test {
  width: 100%; padding: 0.85rem; background: linear-gradient(135deg, #dc2626, #b91c1c);
  color: white; border: none; border-radius: 12px; font-family: var(--font-heading);
  font-size: 0.95rem; font-weight: 800; cursor: pointer; transition: all 0.2s;
  display: flex; align-items: center; justify-content: center; gap: 0.5rem;
}
.btn-submit-test:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(220,38,38,0.35); }

/* Auto-save indicator */
.autosave-indicator {
  display: flex; align-items: center; gap: 0.4rem; font-size: 0.72rem;
  color: var(--gray-400); padding: 0 1rem 0.5rem; justify-content: flex-end;
}
.autosave-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--gray-300); }
.autosave-dot.saving { background: #f59e0b; animation: blink 0.8s infinite; }
.autosave-dot.saved { background: #10b981; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* ── MODALS ── */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(3px);
  display: flex; align-items: center; justify-content: center; z-index: 9999;
  opacity: 0; pointer-events: none; transition: opacity 0.2s;
}
.modal-overlay.active { opacity: 1; pointer-events: all; }
.modal-box {
  background: white; border-radius: 20px; max-width: 520px; width: 90%; max-height: 85vh;
  overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.25);
  transform: scale(0.95); transition: transform 0.2s;
}
.modal-overlay.active .modal-box { transform: scale(1); }
.modal-hdr {
  padding: 1.25rem 1.5rem; border-bottom: 1px solid #f1f5f9;
  display: flex; align-items: center; justify-content: space-between;
}
.modal-hdr h3 { font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: var(--gray-900); }
.modal-close-btn {
  width: 32px; height: 32px; border-radius: 8px; border: none; background: var(--gray-100);
  color: var(--gray-500); cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center;
}
.modal-body { padding: 1.5rem; }
.modal-ftr { padding: 1rem 1.5rem; border-top: 1px solid #f1f5f9; display: flex; gap: 0.6rem; justify-content: flex-end; }

/* Submit summary */
.submit-summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1.25rem; }
.submit-stat-card {
  border-radius: 12px; padding: 0.85rem 1rem; text-align: center;
}
.submit-stat-card .num { font-family: var(--font-heading); font-size: 1.75rem; font-weight: 800; display: block; }
.submit-stat-card .lbl { font-size: 0.78rem; color: var(--gray-500); }
.ssc-answered { background: #dcfce7; } .ssc-answered .num { color: #15803d; }
.ssc-not-answered { background: #fee2e2; } .ssc-not-answered .num { color: #b91c1c; }
.ssc-marked { background: #fef3c7; } .ssc-marked .num { color: #92400e; }
.ssc-not-visited { background: #f1f5f9; } .ssc-not-visited .num { color: var(--gray-500); }
.submit-warning {
  background: #fff7ed; border: 1px solid #fed7aa; border-radius: 10px;
  padding: 0.75rem 1rem; font-size: 0.84rem; color: #9a3412; display: flex; gap: 0.5rem; align-items: flex-start;
}
.submit-warning i { margin-top: 1px; flex-shrink: 0; }

/* Start modal special */
.start-modal-icon { text-align: center; margin-bottom: 1.25rem; }
.start-modal-icon i { font-size: 3rem; color: var(--brand-blue); }
.instructions-list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.25rem; }
.instructions-list li { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.87rem; color: var(--gray-700); line-height: 1.5; }
.instructions-list li i { color: var(--brand-blue); font-size: 0.8rem; margin-top: 3px; flex-shrink: 0; }
.btn-start-test {
  width: 100%; padding: 1rem; background: linear-gradient(135deg, #16a34a, #15803d);
  color: white; border: none; border-radius: 12px; font-family: var(--font-heading);
  font-size: 1.05rem; font-weight: 800; cursor: pointer; transition: all 0.2s;
  display: flex; align-items: center; justify-content: center; gap: 0.6rem;
}
.btn-start-test:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(22,163,74,0.35); }

/* Modal action buttons */
.btn-modal-primary {
  padding: 0.65rem 1.4rem; background: var(--brand-blue); color: white;
  border: none; border-radius: 10px; font-family: var(--font-heading); font-size: 0.88rem;
  font-weight: 700; cursor: pointer; transition: all 0.2s;
}
.btn-modal-primary:hover { background: var(--brand-blue-d); }
.btn-modal-danger {
  padding: 0.65rem 1.4rem; background: #dc2626; color: white;
  border: none; border-radius: 10px; font-family: var(--font-heading); font-size: 0.88rem;
  font-weight: 700; cursor: pointer; transition: all 0.2s;
}
.btn-modal-danger:hover { background: #b91c1c; }
.btn-modal-outline {
  padding: 0.65rem 1.4rem; background: white; color: var(--gray-600);
  border: 1.5px solid #e2e8f0; border-radius: 10px; font-family: var(--font-heading);
  font-size: 0.88rem; font-weight: 700; cursor: pointer; transition: all 0.2s;
}
.btn-modal-outline:hover { border-color: var(--gray-400); }

/* Toast */
#toast-container { position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%); z-index: 99999; display: flex; flex-direction: column; gap: 0.4rem; align-items: center; }
.toast-notification {
  padding: 0.65rem 1.25rem; border-radius: 10px; font-size: 0.85rem; font-weight: 600;
  color: white; box-shadow: 0 4px 16px rgba(0,0,0,0.15); opacity: 0;
  transform: translateY(10px); transition: all 0.3s; font-family: var(--font-body); white-space: nowrap;
}
.toast-notification.show { opacity: 1; transform: translateY(0); }
.toast-notification.success { background: #059669; }
.toast-notification.error { background: #dc2626; }
.toast-notification.warning { background: #d97706; }
.toast-notification.info { background: #0369a1; }

/* ── MOBILE ── */
@media (max-width: 1024px) {
  .sidebar-panel {
    position: fixed; top: 58px; right: 0; bottom: 0;
    transform: translateX(100%); transition: transform 0.3s ease;
    z-index: 200; box-shadow: -4px 0 20px rgba(0,0,0,0.15);
  }
  .sidebar-panel.active { transform: translateX(0); }
  .sidebar-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.4);
    z-index: 199; display: none;
  }
  .sidebar-overlay.active { display: block; }
  .question-footer-pro { right: 0; }
  .test-meta-badges { display: none; }
  #test-title { max-width: 160px; }
}
@media (max-width: 640px) {
  .btn-action span { display: none; }
  .question-content-pro { padding: 1rem 1rem 5rem; }
  .question-footer-pro { gap: 0.4rem; padding: 0.6rem 0.75rem; }
}

/* ── Very small phones (360-390px) ── */
@media (max-width: 400px) {
  /* Shrink header elements so they all fit */
  #test-title { max-width: 110px; font-size: 0.82rem; }
  .test-logo { width: 26px; height: 26px; }
  .timer-box { padding: 0.35rem 0.55rem; }
  #test-timer { font-size: 0.92rem; min-width: 60px; }
  .btn-header { padding: 0.35rem 0.55rem; font-size: 0.72rem; }
  .btn-header span { display: none; }
  .test-header-pro { padding: 0 0.75rem; }
  /* Footer buttons icon-only on tiny screens */
  .question-footer-pro { padding: 0.5rem 0.6rem; gap: 0.3rem; }
  .btn-action { padding: 0.55rem 0.65rem; font-size: 0; }
  .btn-action i { font-size: 0.95rem; }
  .btn-action.btn-save-next::after { content: 'Save'; font-size: 0.75rem; }
  .footer-spacer { display: none; }
}
</style>

<main class="test-interface-fullscreen noselect">

  <!-- ── TOP HEADER ── -->
  <div class="test-header-pro">
    <div class="test-header-content">
      <div class="test-info">
        <img src="/images/logo.jpeg" class="test-logo" alt="Logo">
        <h1 id="test-title">Loading...</h1>
        <div class="test-meta-badges">
          <span class="test-meta-badge" id="test-subject-badge">—</span>
          <span class="test-meta-badge" id="test-diff-badge">—</span>
        </div>
      </div>
      <div class="test-controls">
        <!-- Auto-save indicator -->
        <div class="autosave-indicator" id="autosave-indicator" style="display:none;">
          <div class="autosave-dot" id="autosave-dot"></div>
          <span id="autosave-text">Saved</span>
        </div>
        <!-- Timer -->
        <div class="timer-box" id="timer-box">
          <i class="fas fa-clock"></i>
          <span id="test-timer">00:00:00</span>
        </div>
        <!-- Mobile palette toggle -->
        <button class="btn-header" id="toggle-sidebar-btn" style="display:none;" aria-label="Question Palette">
          <i class="fas fa-th-large"></i> <span>Palette</span>
        </button>
        <!-- Lang toggle -->
        <button class="btn-header" id="toggle-lang-btn" title="Switch Language">
          <i class="fas fa-language"></i> <span id="lang-label">हिंदी</span>
        </button>
        <!-- Fullscreen -->
        <button class="btn-header" id="fullscreen-btn" title="Fullscreen">
          <i class="fas fa-expand" id="fullscreen-icon"></i>
        </button>
        <!-- Instructions -->
        <button class="btn-header" id="instructions-btn" title="Instructions">
          <i class="fas fa-info-circle"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- ── BODY ── -->
  <div class="test-body">

    <!-- QUESTION PANEL -->
    <div class="question-panel-pro">

      <!-- Section tabs (only for 150Q tests) -->
      <div class="question-panel-header">
        <div id="test-section-tabs" class="section-tabs" style="display:none;">
          <button class="section-tab active" data-section="p1">Paper I (1–50)</button>
          <button class="section-tab" data-section="p2">Paper II (51–100)</button>
        </div>
        <div class="panel-actions" id="panel-actions-placeholder"></div>
      </div>

      <!-- Question Counter Strip -->
      <div class="question-counter-strip">
        <div class="q-counter-label">
          Question <span id="current-q">—</span> of <span id="total-qs">—</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.6rem;">
          <span class="q-status-badge not-visited" id="current-q-status">Not Visited</span>
          <div class="q-nav-arrows">
            <button class="btn-q-nav" id="prev-q-btn" title="Previous"><i class="fas fa-chevron-left"></i></button>
            <button class="btn-q-nav" id="next-q-btn" title="Next"><i class="fas fa-chevron-right"></i></button>
          </div>
        </div>
      </div>

      <!-- Question + Options -->
      <div class="question-content-pro" id="question-scroll-area">
        <div class="question-text" id="question-text">
          <div style="display:flex;align-items:center;gap:0.75rem;color:var(--gray-400);font-size:0.9rem;">
            <i class="fas fa-spinner fa-spin"></i> Loading question...
          </div>
        </div>
        <div class="options-container" id="options-container"></div>
      </div>

    </div>

    <!-- SIDEBAR -->
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div class="sidebar-panel" id="sidebar-panel">

      <!-- User card -->
      <div class="sidebar-user-card">
        <img src="<%= (locals.user && locals.user.avatar) ? locals.user.avatar : '/images/default-avatar.png' %>"
             alt="Avatar" class="sidebar-avatar"
             onerror="this.src='/images/default-avatar.png'">
        <div>
          <div class="sidebar-user-name"><%= (locals.user && locals.user.fullname) ? locals.user.fullname : 'Guest' %></div>
          <div class="sidebar-user-role">Test Taker</div>
        </div>
      </div>

      <!-- Live stats -->
      <div class="sidebar-stats">
        <div class="sidebar-stat s-answered"><strong id="stat-answered">0</strong><span>Answered</span></div>
        <div class="sidebar-stat s-not-ans"><strong id="stat-not-answered">0</strong><span>Skipped</span></div>
        <div class="sidebar-stat s-marked"><strong id="stat-marked">0</strong><span>Marked</span></div>
        <div class="sidebar-stat s-not-vis"><strong id="stat-not-visited">0</strong><span>Unseen</span></div>
      </div>

      <!-- Legend + Palette -->
      <div class="palette-section">
        <div class="palette-title">Question Palette</div>
        <div class="palette-legend">
          <div class="legend-row"><span class="legend-dot answered"></span>Answered</div>
          <div class="legend-row"><span class="legend-dot not-answered"></span>Not Answered</div>
          <div class="legend-row"><span class="legend-dot marked-for-review"></span>Marked for Review</div>
          <div class="legend-row"><span class="legend-dot answered-review"></span>Answered + Marked</div>
          <div class="legend-row"><span class="legend-dot not-visited"></span>Not Visited</div>
        </div>
      </div>
      <div class="palette-grid-wrap">
        <div class="question-palette-grid" id="question-palette"></div>
      </div>

      <!-- Auto-save info -->
      <div class="autosave-indicator" id="sidebar-autosave" style="justify-content:center;padding:0.25rem 0 0.5rem;">
        <div class="autosave-dot saved" id="sidebar-save-dot"></div>
        <span id="sidebar-save-text" style="font-size:0.72rem;color:var(--gray-400);">Progress auto-saved</span>
      </div>

      <!-- Submit -->
      <div class="sidebar-submit-area">
        <button class="btn-submit-test" id="submit-test">
          <i class="fas fa-paper-plane"></i> Submit Test
        </button>
      </div>
    </div>

  </div>

  <!-- FOOTER ACTIONS -->
  <div class="question-footer-pro">
    <button class="btn-action btn-save-next" id="save-next">
      <i class="fas fa-check"></i> <span>Save &amp; Next</span>
    </button>
    <button class="btn-action btn-save-review" id="save-review">
      <i class="fas fa-bookmark"></i> <span>Save &amp; Mark</span>
    </button>
    <button class="btn-action btn-mark-review" id="mark-review">
      <i class="far fa-bookmark"></i> <span>Mark &amp; Next</span>
    </button>
    <button class="btn-action btn-clear" id="clear-response">
      <i class="fas fa-eraser"></i> <span>Clear</span>
    </button>
  </div>

  <!-- Toast container -->
  <div id="toast-container"></div>



<!-- ══ START MODAL ══ -->
<div class="modal-overlay active" id="start-test-modal">
  <div class="modal-box">
    <div class="modal-body" style="text-align:center;">
      <div class="start-modal-icon"><i class="fas fa-graduation-cap"></i></div>
      <h2 style="font-family:var(--font-heading);font-size:1.35rem;font-weight:800;color:var(--gray-900);margin-bottom:0.5rem;">Ready to Begin?</h2>
      <p style="color:var(--gray-500);font-size:0.88rem;margin-bottom:1.5rem;">Please read the instructions carefully before starting.</p>
      <ul class="instructions-list" style="text-align:left;">
        <li><i class="fas fa-clock"></i> The timer starts the moment you click "Start Test"</li>
        <li><i class="fas fa-expand"></i> The test opens in fullscreen — do not exit</li>
        <li><i class="fas fa-bookmark"></i> Use "Mark for Review" to flag questions you want to revisit</li>
        <li><i class="fas fa-save"></i> Your progress is auto-saved every 15 seconds</li>
        <li><i class="fas fa-wifi"></i> Going offline? Progress is also saved locally</li>
        <li><i class="fas fa-times-circle"></i> There is <strong>no negative marking</strong> in this test</li>
        <li><i class="fas fa-star"></i> Each correct answer carries <strong>2 marks</strong></li>
      </ul>
<button class="btn-start-test" id="confirm-start-test">        <i class="fas fa-play"></i> Start Test Now
      </button>
    </div>
  </div>
</div>

<!-- ══ INSTRUCTIONS MODAL ══ -->
<div class="modal-overlay" id="instructions-modal">
  <div class="modal-box">
    <div class="modal-hdr">
      <h3><i class="fas fa-info-circle" style="color:var(--brand-blue);margin-right:.5rem;"></i>Test Instructions</h3>
      <button class="modal-close-btn modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <ul class="instructions-list">
        <li><i class="fas fa-question-circle"></i> Total questions: <strong id="inst-total-q">100</strong></li>
        <li><i class="fas fa-clock"></i> Duration: <strong id="inst-duration">180 minutes</strong></li>
        <li><i class="fas fa-star"></i> Each question carries <strong>2 marks</strong></li>
        <li><i class="fas fa-ban"></i> No negative marking</li>
        <li><i class="fas fa-th"></i> Use the palette on the right to jump to any question</li>
        <li><i class="fas fa-bookmark"></i> "Mark for Review" flags a question — it's still counted if answered</li>
        <li><i class="fas fa-eraser"></i> "Clear Response" removes your selected option</li>
        <li><i class="fas fa-save"></i> Click "Submit Test" only when you're done — it cannot be undone</li>
      </ul>
    </div>
    <div class="modal-ftr"><button class="btn-modal-primary modal-close">Got it</button></div>
  </div>
</div>

<!-- ══ SUBMIT MODAL ══ -->
<div class="modal-overlay" id="submit-modal">
  <div class="modal-box">
    <div class="modal-hdr">
      <h3><i class="fas fa-paper-plane" style="color:#dc2626;margin-right:.5rem;"></i>Submit Test</h3>
      <button class="modal-close-btn" id="cancel-submit"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div class="submit-summary-grid">
        <div class="submit-stat-card ssc-answered"><span class="num" id="final-answered">0</span><span class="lbl">Answered</span></div>
        <div class="submit-stat-card ssc-not-answered"><span class="num" id="final-not-answered">0</span><span class="lbl">Not Answered</span></div>
        <div class="submit-stat-card ssc-marked"><span class="num" id="final-marked">0</span><span class="lbl">Marked for Review</span></div>
        <div class="submit-stat-card ssc-not-visited"><span class="num" id="final-not-visited">0</span><span class="lbl">Not Visited</span></div>
      </div>
      <div class="submit-warning">
        <i class="fas fa-exclamation-triangle"></i>
        <span>Once submitted, you <strong>cannot change your answers</strong>. Make sure you've reviewed all questions.</span>
      </div>
    </div>
    <div class="modal-ftr">
      <button class="btn-modal-outline" id="cancel-submit-2">Go Back & Review</button>
      <button class="btn-modal-danger" id="confirm-submit"><i class="fas fa-paper-plane"></i> Yes, Submit</button>
    </div>
  </div>
</div>
</main>
<script>
// ── OPTION CLICK HANDLER (enhances existing test-interface.js) ──
document.addEventListener('DOMContentLoaded', () => {
  // Make option items clickable as a whole div
  document.getElementById('options-container').addEventListener('click', (e) => {
    const item = e.target.closest('.option-item');
    if (!item) return;
    const radio = item.querySelector('input[type="radio"]');
    if (radio) {
      radio.checked = true;
      document.querySelectorAll('.option-item').forEach(o => o.classList.remove('selected'));
      item.classList.add('selected');
    }
  });

  // Mobile sidebar overlay close
  document.getElementById('sidebar-overlay')?.addEventListener('click', () => {
    document.getElementById('sidebar-panel')?.classList.remove('active');
    document.getElementById('sidebar-overlay')?.classList.remove('active');
  });

  // Show mobile palette button
  if (window.innerWidth <= 1024) {
    const btn = document.getElementById('toggle-sidebar-btn');
    if (btn) btn.style.display = 'flex';
  }

  // Toggle sidebar on mobile
  document.getElementById('toggle-sidebar-btn')?.addEventListener('click', (e) => {
    e.stopPropagation();
    document.getElementById('sidebar-panel')?.classList.toggle('active');
    document.getElementById('sidebar-overlay')?.classList.toggle('active');
  });

  // Modal close buttons
  document.querySelectorAll('.modal-close').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.modal-overlay')?.classList.remove('active');
    });
  });
  document.getElementById('cancel-submit')?.addEventListener('click', () => {
    document.getElementById('submit-modal')?.classList.remove('active');
  });
  document.getElementById('cancel-submit-2')?.addEventListener('click', () => {
    document.getElementById('submit-modal')?.classList.remove('active');
  });
  document.getElementById('instructions-btn')?.addEventListener('click', () => {
    document.getElementById('instructions-modal')?.classList.add('active');
  });

  // Autosave visual indicator — hooked by test-interface.js
  window.showAutosaveState = function(state) {
    const dot = document.getElementById('autosave-dot');
    const text = document.getElementById('autosave-text');
    const sidebarDot = document.getElementById('sidebar-save-dot');
    const sidebarText = document.getElementById('sidebar-save-text');
    const indicator = document.getElementById('autosave-indicator');
    if(indicator) indicator.style.display = 'flex';

    if (state === 'saving') {
      if(dot) { dot.className='autosave-dot saving'; }
      if(text) text.textContent = 'Saving...';
      if(sidebarDot) sidebarDot.className='autosave-dot saving';
      if(sidebarText) sidebarText.textContent = 'Saving...';
    } else if (state === 'saved') {
      if(dot) dot.className='autosave-dot saved';
      if(text) text.textContent = 'Saved ✓';
      if(sidebarDot) sidebarDot.className='autosave-dot saved';
      if(sidebarText) sidebarText.textContent = 'Progress auto-saved ✓';
    } else {
      if(dot) dot.className='autosave-dot';
      if(text) text.textContent = 'Offline';
    }
  };

  // Timer color states
  window.setTimerWarning = function(level) {
    const box = document.getElementById('timer-box');
    if (!box) return;
    box.className = 'timer-box' + (level === 'warning' ? ' warning' : level === 'danger' ? ' danger' : '');
  };

  // Current question status badge update
  window.updateQStatusBadge = function(status) {
    const badge = document.getElementById('current-q-status');
    if (!badge) return;
    const labels = {
      'not-visited': 'Not Visited',
      'not-answered': 'Not Answered',
      'answered': 'Answered',
      'marked-for-review': 'Marked for Review',
      'answered-review': 'Answered + Marked',
    };
    badge.className = 'q-status-badge ' + (status || 'not-visited');
    badge.textContent = labels[status] || 'Not Visited';
  };

  // Prev/Next arrow buttons (supplement test-interface.js)
  document.getElementById('prev-q-btn')?.addEventListener('click', () => {
    const currentQ = parseInt(document.getElementById('current-q')?.textContent || '1');
    if (currentQ > 1) {
      const paletteBtn = document.querySelector(`.palette-btn[data-index="${currentQ - 2}"]`);
      paletteBtn?.click();
    }
  });
  document.getElementById('next-q-btn')?.addEventListener('click', () => {
    const currentQ = parseInt(document.getElementById('current-q')?.textContent || '1');
    const totalQ = parseInt(document.getElementById('total-qs')?.textContent || '0');
    if (currentQ < totalQ) {
      const paletteBtn = document.querySelector(`.palette-btn[data-index="${currentQ}"]`);
      paletteBtn?.click();
    }
  });

  // Update prev/next button state
  const origRenderQ = window.__testMgrRenderQ;
  const updateNavBtns = () => {
    const currentQ = parseInt(document.getElementById('current-q')?.textContent || '1');
    const totalQ = parseInt(document.getElementById('total-qs')?.textContent || '0');
    const prevBtn = document.getElementById('prev-q-btn');
    const nextBtn = document.getElementById('next-q-btn');
    if(prevBtn) prevBtn.disabled = currentQ <= 1;
    if(nextBtn) nextBtn.disabled = currentQ >= totalQ;
  };
  // Poll for question changes (works alongside test-interface.js)
  setInterval(updateNavBtns, 500);
});
</script>

