<%- include('partials/admin-header', { title: 'Question Bank', page: 'questions' }) %>
<script src="https://cdn.tiny.cloud/1/c1pzppo66j4eomef1luao5fnhrq9nmtpee1trlvnkjwvzv10/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
<main class="main-content">
    <header class="main-header">
        <h1><i class="fas fa-database"></i> Question Bank Manager</h1>
        <div class="header-actions">
            <span class="badge-count" id="total-questions-count">0 Questions Found</span>
        </div>
    </header>

    <section class="content-area">
        
        <div class="content-block" style="margin-bottom: 20px;">
            <div class="filter-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 15px; align-items: end;">
                
                <div class="input-group">
                    <label for="qSearch">Search</label>
                    <input type="text" id="qSearch" placeholder="Keywords..." class="form-input">
                </div>

                <div class="input-group">
                    <label for="qPaper">Paper</label>
                    <select id="qPaper" class="form-input">
                        <option value="">All Papers</option>
                        <option value="Paper 1">Paper 1</option>
                        <option value="Paper 2">Paper 2</option>
                    </select>
                </div>

                <div class="input-group">
                    <label for="qYear">Year</label>
                    <select id="qYear" class="form-input">
                        <option value="">All Years</option>
                        <option value="2025">2025</option>
                        <option value="2024">2024</option>
                        <option value="2023">2023</option>
                    </select>
                </div>

                <div class="input-group">
                    <label for="qMonth">Month</label>
                    <select id="qMonth" class="form-input">
                        <option value="">All Months</option>
                        <option value="June">June</option>
                        <option value="December">December</option>
                        <option value="January">January</option>
                    </select>
                </div>

                <div class="input-group">
                    <label for="qUnit">Unit</label>
                    <select id="qUnit" class="form-input">
                        <option value="">All Units</option>
                    </select>
                </div>

                <div style="display: flex; gap: 10px; align-items: center;">
                    <button id="applyFiltersBtn" class="btn btn-primary" style="flex: 1; height: 42px;">
                        <i class="fas fa-filter"></i> Apply
                    </button>
                    
                    <button type="button" id="generalFilterBtn" class="btn btn-secondary" style="height: 42px; background: #f0f9ff; color: #0369a1; border: 1px solid #bae6fd;" title="Show General unit questions first">
                        <i class="fas fa-star"></i> General First
                    </button>
                    
                    <button type="button" id="bulkDeleteBtn" class="btn btn-danger" style="background: #fee2e2; color: #dc2626; border: 1px solid #fca5a5; height: 42px; padding: 0 15px;" title="Delete all questions currently filtered">
                        <i class="fas fa-trash"></i> Delete All
                    </button>
                </div>
            </div>
        </div>

        <div class="content-block">
            <div id="questions-loader" style="text-align:center; padding:20px; display:none;">
                <div class="spinner"></div> Loading...
            </div>
            
            <div id="questions-container">
                <!-- Questions will be loaded here -->
            </div>

            <div class="pagination-controls" id="qPagination" style="margin-top: 20px; display: flex; justify-content: center; gap: 10px;">
                <!-- Pagination will be loaded here -->
            </div>
        </div>

    </section>
</main>

<style>
    /* Page specific styles */
    .q-card { 
        border: 1px solid #e2e8f0; 
        border-radius: 8px; 
        padding: 15px; 
        margin-bottom: 15px; 
        background: white; 
        transition: transform 0.2s; 
    }
    .q-card:hover { 
        border-color: #cbd5e1; 
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); 
    }
    .q-meta { 
        display: flex; 
        gap: 10px; 
        margin-bottom: 10px; 
        font-size: 0.85rem; 
        color: #64748b; 
        flex-wrap: wrap; 
    }
    .q-tag { 
        background: #f1f5f9; 
        padding: 4px 10px; 
        border-radius: 6px; 
        border: 1px solid #e2e8f0; 
        font-size: 0.8rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .q-tag.paper { 
        background: #e0f2fe; 
        color: #0284c7; 
        border-color: #bae6fd; 
    }
    .q-tag.unit { 
        background: #f0fdf4; 
        color: #16a34a; 
        border-color: #bbf7d0; 
    }
    .q-tag.unit.general { 
        background: #fef3c7; 
        color: #92400e; 
        border-color: #f59e0b; 
        font-weight: 600;
    }
    .q-text { 
        font-weight: 500; 
        color: #1e293b; 
        margin-bottom: 10px; 
        font-size: 1rem; 
        line-height: 1.5;
    }
    .q-actions { 
        display: flex; 
        justify-content: flex-end; 
        border-top: 1px solid #f1f5f9; 
        padding-top: 10px; 
        margin-top: 10px; 
        gap: 8px;
    }
    
    /* Modal Styles */
    #fullEditModal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.7);
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
        overflow-y: auto;
    }
    
    .modal-content {
        background: white;
        border-radius: 12px;
        width: 100%;
        max-width: 900px;
        max-height: 90vh;
        overflow-y: auto;
        position: relative;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    }
    
    .modal-header {
        padding: 20px 30px;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        background: white;
        z-index: 10;
        border-radius: 12px 12px 0 0;
    }
    
    .modal-body {
        padding: 0 30px 30px;
    }
    
    .close-modal {
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: #666;
        padding: 5px;
        line-height: 1;
    }
    
    .close-modal:hover {
        color: #333;
    }
    
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }
    
    .option-row {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
        align-items: center;
    }
    
    .option-row input[type="radio"] {
        margin: 0;
    }
    
    .option-row .form-input {
        flex: 1;
    }
    
    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        border-top: 1px solid #eee;
        padding-top: 20px;
        margin-top: 20px;
        position: sticky;
        bottom: 0;
        background: white;
        padding-bottom: 30px;
        border-radius: 0 0 12px 12px;
    }
</style>

<!-- Edit Modal -->
<div id="fullEditModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 style="margin: 0; color: #333;">
                <i class="fas fa-check-circle" style="color: #0284c7;"></i> Verify & Edit Question
            </h2>
            <button type="button" class="close-modal" data-close-modal>
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <div class="modal-body">
            <form id="fullEditForm">
                <input type="hidden" id="edit-q-id">

                <div style="background: #f8fafc; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                    <div class="form-row">
                        <div>
                            <label style="font-weight: 600; font-size: 0.9em; color: #64748b; display: block; margin-bottom: 5px;">Paper Type</label>
                            <select id="edit-paper" class="form-input">
                                <option value="Paper 1">Paper 1 (General)</option>
                                <option value="Paper 2">Paper 2 (Pol Sci)</option>
                            </select>
                        </div>
                        <div>
                            <label style="font-weight: 600; font-size: 0.9em; color: #64748b; display: block; margin-bottom: 5px;">Unit (Topic)</label>
                            <select id="edit-unit" class="form-input">
                                <!-- Options will be populated by JavaScript -->
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div>
                        <label style="font-weight: 600; display:block; margin-bottom:5px;">Question (English)</label>
                        <textarea id="edit-q-en" class="rich-editor" style="height: 150px;"></textarea>
                    </div>
                    <div>
                        <label style="font-weight: 600; display:block; margin-bottom:5px;">Question (Hindi)</label>
                        <textarea id="edit-q-hi" class="rich-editor" style="height: 150px;"></textarea>
                    </div>
                </div>

                <h4 style="margin-bottom: 15px; color: #444;">Options (Select Correct Answer)</h4>
                <div style="background: #f9f9f9; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                    <div class="option-row">
                        <input type="radio" name="editCorrect" value="0">
                        <input type="text" id="edit-opt1-en" class="form-input" placeholder="Option A (English)">
                        <input type="text" id="edit-opt1-hi" class="form-input" placeholder="Option A (Hindi)">
                    </div>
                    <div class="option-row">
                        <input type="radio" name="editCorrect" value="1">
                        <input type="text" id="edit-opt2-en" class="form-input" placeholder="Option B (English)">
                        <input type="text" id="edit-opt2-hi" class="form-input" placeholder="Option B (Hindi)">
                    </div>
                    <div class="option-row">
                        <input type="radio" name="editCorrect" value="2">
                        <input type="text" id="edit-opt3-en" class="form-input" placeholder="Option C (English)">
                        <input type="text" id="edit-opt3-hi" class="form-input" placeholder="Option C (Hindi)">
                    </div>
                    <div class="option-row">
                        <input type="radio" name="editCorrect" value="3">
                        <input type="text" id="edit-opt4-en" class="form-input" placeholder="Option D (English)">
                        <input type="text" id="edit-opt4-hi" class="form-input" placeholder="Option D (Hindi)">
                    </div>
                </div>

                <div style="margin-top: 20px;">
                    <label style="font-weight: 600; display:block; margin-bottom:5px;">Explanation</label>
                    <textarea id="edit-expl" class="rich-editor" style="height: 200px;"></textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn" data-close-modal style="background: #e2e8f0; color: #333;">Cancel</button>
                    <button type="submit" class="btn btn-primary" style="padding: 10px 30px; font-weight: bold;">
                        <i class="fas fa-save"></i> Update Question
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/admin-footer') %>