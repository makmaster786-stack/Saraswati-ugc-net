<%- include('partials/header-professional', { title: 'Login', script: '/js/auth.js' }) %>

<style>
/* ── AUTH PAGE ── */
.auth-page { min-height: 100vh; background: var(--gray-50); display: flex; align-items: stretch; }
.auth-split { display: grid; grid-template-columns: 1fr 1.1fr; min-height: 100vh; width: 100%; }

/* LEFT PANEL — Form */
.auth-left {
  display: flex; flex-direction: column; justify-content: center; align-items: center;
  padding: 3rem 2rem; background: white; position: relative; overflow: hidden;
}
.auth-left::before {
  content: ''; position: absolute; top: -80px; right: -80px;
  width: 250px; height: 250px; border-radius: 50%;
  background: radial-gradient(circle, rgba(14,165,233,0.06), transparent 70%);
}

.auth-form-box { width: 100%; max-width: 400px; }
.auth-logo-link {
  display: flex; align-items: center; gap: 0.6rem;
  font-family: var(--font-heading); font-weight: 800; font-size: 1.1rem;
  color: var(--brand-blue-d); text-decoration: none; margin-bottom: 2.5rem;
}
.auth-logo-link img { width: 36px; height: 36px; border-radius: 8px; }

.auth-heading { font-family: var(--font-heading); font-size: 1.75rem; font-weight: 800; color: var(--gray-900); margin-bottom: 0.35rem; }
.auth-subheading { color: var(--gray-500); font-size: 0.9rem; margin-bottom: 2rem; }

/* Google Button */
.btn-google {
  width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.75rem;
  padding: 0.75rem 1rem; border: 1.5px solid var(--gray-200); border-radius: 12px;
  background: white; color: var(--gray-700); font-weight: 600; font-size: 0.9rem;
  cursor: pointer; transition: all 0.2s; font-family: var(--font-body); text-decoration: none;
}
.btn-google:hover { border-color: #4285F4; background: #fafbff; box-shadow: 0 4px 12px rgba(66,133,244,0.12); }

.auth-divider {
  display: flex; align-items: center; gap: 1rem;
  margin: 1.25rem 0; color: var(--gray-400); font-size: 0.82rem;
}
.auth-divider::before, .auth-divider::after {
  content: ''; flex: 1; height: 1px; background: var(--gray-200);
}

/* Form fields */
.auth-field { margin-bottom: 1.1rem; }
.auth-label { display: block; font-size: 0.82rem; font-weight: 700; color: var(--gray-600); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.04em; }
.auth-input {
  width: 100%; padding: 0.75rem 1rem; border: 1.5px solid var(--gray-200); border-radius: 10px;
  font-family: var(--font-body); font-size: 0.9rem; color: var(--gray-800); background: white;
  transition: border-color 0.2s, box-shadow 0.2s; outline: none;
}
.auth-input:focus { border-color: var(--brand-blue); box-shadow: 0 0 0 3px rgba(14,165,233,0.1); }
.auth-input::placeholder { color: var(--gray-300); }
.auth-input.error { border-color: #ef4444; }

/* Password field wrapper */
.input-group { position: relative; }
.input-group .auth-input { padding-right: 2.75rem; }
.toggle-pw {
  position: absolute; right: 0.9rem; top: 50%; transform: translateY(-50%);
  background: none; border: none; cursor: pointer; color: var(--gray-400);
  font-size: 0.9rem; padding: 0;
}
.toggle-pw:hover { color: var(--gray-700); }

.auth-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
.remember-label { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--gray-600); cursor: pointer; }
.remember-label input { accent-color: var(--brand-blue); }
.auth-link { color: var(--brand-blue); text-decoration: none; font-size: 0.85rem; font-weight: 600; }
.auth-link:hover { text-decoration: underline; }

.btn-auth {
  width: 100%; padding: 0.85rem; background: linear-gradient(135deg, var(--brand-blue), var(--brand-blue-d));
  color: white; border: none; border-radius: 12px; font-family: var(--font-heading);
  font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.2s; display: flex;
  align-items: center; justify-content: center; gap: 0.5rem;
}
.btn-auth:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(14,165,233,0.35); }
.btn-auth:disabled { opacity: 0.7; transform: none; cursor: not-allowed; }

.auth-switch { text-align: center; margin-top: 1.5rem; font-size: 0.88rem; color: var(--gray-500); }

.auth-error-banner {
  background: #fee2e2; border: 1px solid #fca5a5; border-radius: 10px;
  padding: 0.75rem 1rem; margin-bottom: 1.25rem; color: #b91c1c;
  font-size: 0.85rem; display: flex; align-items: center; gap: 0.5rem;
}

/* RIGHT PANEL — Benefits */
.auth-right {
  background: linear-gradient(145deg, #0c4a6e 0%, #0369a1 50%, #0EA5E9 100%);
  display: flex; flex-direction: column; justify-content: center; align-items: center;
  padding: 3rem 2.5rem; position: relative; overflow: hidden;
}
.auth-right::before {
  content: ''; position: absolute; top: -100px; right: -100px;
  width: 400px; height: 400px; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.06), transparent 60%);
}
.auth-right::after {
  content: ''; position: absolute; bottom: -80px; left: -80px;
  width: 300px; height: 300px; border-radius: 50%;
  background: radial-gradient(circle, rgba(245,158,11,0.15), transparent 60%);
}

.auth-right-content { max-width: 380px; position: relative; z-index: 1; }
.auth-right h2 {
  font-family: var(--font-heading); font-size: 1.9rem; font-weight: 800;
  color: white; line-height: 1.25; margin-bottom: 0.75rem;
}
.auth-right > .auth-right-content > p { color: rgba(255,255,255,0.8); font-size: 0.95rem; margin-bottom: 2rem; }

/* Stats row */
.auth-stats { display: flex; gap: 2rem; margin-bottom: 2.5rem; }
.auth-stat { text-align: center; }
.auth-stat-num { font-family: var(--font-heading); font-size: 1.6rem; font-weight: 800; color: white; display: block; }
.auth-stat-lbl { font-size: 0.75rem; color: rgba(255,255,255,0.7); }

/* Feature list */
.auth-features-list { display: flex; flex-direction: column; gap: 1rem; }
.auth-feature-item {
  display: flex; align-items: flex-start; gap: 0.9rem;
  background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px; padding: 0.9rem 1.1rem; backdrop-filter: blur(8px);
}
.auth-feature-icon {
  width: 36px; height: 36px; background: rgba(255,255,255,0.15); border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  color: var(--brand-gold); font-size: 0.95rem; flex-shrink: 0;
}
.auth-feature-text h4 { font-family: var(--font-heading); color: white; font-size: 0.88rem; font-weight: 700; margin-bottom: 0.2rem; }
.auth-feature-text p { color: rgba(255,255,255,0.7); font-size: 0.8rem; margin: 0; line-height: 1.5; }

/* Responsive */
@media (max-width: 900px) { .auth-right { display: none; } .auth-split { grid-template-columns: 1fr; } }
@media (max-width: 480px) { .auth-left { padding: 2rem 1.25rem; } }
</style>

<main class="auth-page" style="padding-top:0;">
  <div class="auth-split">

    <!-- ── LEFT: FORM ── -->
    <div class="auth-left">
      <div class="auth-form-box">

        <a href="/" class="auth-logo-link">
          <img src="/images/logo.jpeg" alt="Logo">
          Saraswati UGC NET
        </a>

        <h1 class="auth-heading">Welcome back! 👋</h1>
        <p class="auth-subheading">Login to access your dashboard, tests and courses.</p>

        <% if (locals.error) { %>
        <div class="auth-error-banner">
          <i class="fas fa-exclamation-circle"></i> <%= error %>
        </div>
        <% } %>

        <!-- Google Login -->
        <a href="/api/auth/google?action=login" class="btn-google">
          <svg width="20" height="20" viewBox="0 0 18 18"><path d="M17.64 9.2c0-.637-.057-1.252-.164-1.841H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/><path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.715H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/><path d="M3.964 10.706a5.41 5.41 0 0 1-.282-1.706c0-.593.102-1.17.282-1.706V4.962H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.038l3.007-2.332z" fill="#FBBC05"/><path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.962l3.007 2.332c.708-2.131 2.692-3.715 5.036-3.715z" fill="#EA4335"/></svg>
          Continue with Google
        </a>

        <div class="auth-divider"><span>or login with email</span></div>

        <form id="loginForm" novalidate>
          <div class="auth-field">
            <label class="auth-label" for="email">Email Address</label>
            <input type="email" id="email" name="email" class="auth-input" placeholder="you@example.com" required autocomplete="email">
          </div>
          <div class="auth-field">
            <label class="auth-label" for="password">Password</label>
            <div class="input-group">
              <input type="password" id="password" name="password" class="auth-input" placeholder="Enter your password" required autocomplete="current-password">
              <button type="button" class="toggle-pw" id="toggle-pw-btn" aria-label="Show password">
                <i class="fas fa-eye" id="pw-eye"></i>
              </button>
            </div>
          </div>
          <div class="auth-row">
            <label class="remember-label">
              <input type="checkbox" name="remember"> Remember me
            </label>
            <a href="/forgot-password" class="auth-link">Forgot Password?</a>
          </div>
          <button type="submit" class="btn-auth" id="login-btn">
            <i class="fas fa-sign-in-alt"></i> Login to Dashboard
          </button>
        </form>

        <p class="auth-switch">Don't have an account? <a href="/signup" class="auth-link">Sign up free →</a></p>
      </div>
    </div>

    <!-- ── RIGHT: BENEFITS ── -->
    <div class="auth-right">
      <div class="auth-right-content">
        <h2>Resume Your UGC NET Journey</h2>
        <p>Thousands of students trust Saraswati UGC NET to crack their exam.</p>

        <div class="auth-stats">
          <div class="auth-stat"><span class="auth-stat-num">5K+</span><span class="auth-stat-lbl">Students</span></div>
          <div class="auth-stat"><span class="auth-stat-num">98%</span><span class="auth-stat-lbl">Success Rate</span></div>
          <div class="auth-stat"><span class="auth-stat-num">100+</span><span class="auth-stat-lbl">Mock Tests</span></div>
        </div>

        <div class="auth-features-list">
          <div class="auth-feature-item">
            <div class="auth-feature-icon"><i class="fas fa-play-circle"></i></div>
            <div class="auth-feature-text">
              <h4>Resume Your Tests</h4>
              <p>Pick up exactly where you left off — progress is auto-saved.</p>
            </div>
          </div>
          <div class="auth-feature-item">
            <div class="auth-feature-icon"><i class="fas fa-chart-pie"></i></div>
            <div class="auth-feature-text">
              <h4>Detailed Analytics</h4>
              <p>See your unit-wise performance and improvement over time.</p>
            </div>
          </div>
          <div class="auth-feature-item">
            <div class="auth-feature-icon"><i class="fas fa-language"></i></div>
            <div class="auth-feature-text">
              <h4>Bilingual Content</h4>
              <p>Switch between English and Hindi on every question.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<script>
// Toggle password visibility
document.getElementById('toggle-pw-btn')?.addEventListener('click', () => {
  const input = document.getElementById('password');
  const icon  = document.getElementById('pw-eye');
  if (input.type === 'password') { input.type = 'text'; icon.classList.replace('fa-eye','fa-eye-slash'); }
  else { input.type = 'password'; icon.classList.replace('fa-eye-slash','fa-eye'); }
});
</script>

<%- include('partials/footer-professional') %>
