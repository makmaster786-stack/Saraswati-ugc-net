<body>
    <div class="admin-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <h3><i class="fas fa-graduation-cap"></i> Admin Panel</h3>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li class="<%= page === 'dashboard' ? 'active' : '' %>">
                        <a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> <span>Dashboard</span></a>
                    </li>
                    <li class="<%= page === 'students' ? 'active' : '' %>">
                        <a href="/admin/students"><i class="fas fa-users"></i> <span>Students</span></a>
                    </li>
                    <li class="<%= page === 'courses' ? 'active' : '' %>">
                        <a href="/admin/courses"><i class="fas fa-book-open"></i> <span>Courses</span></a>
                    </li>
                    <li class="<%= page === 'tests' ? 'active' : '' %>">
                        <a href="/admin/tests"><i class="fas fa-file-alt"></i> <span>Tests</span></a>
                    </li>
                    <li class="<%= page === 'knowledge' ? 'active' : '' %>">
                        <a href="/admin/knowledge-base"><i class="fas fa-lightbulb"></i> <span>Knowledge Base</span></a>
                    </li>
                     <li class="<%= page === 'resources' ? 'active' : '' %>">
                        <a href="/admin/resources"><i class="fas fa-file-pdf"></i> <span>Resources</span></a>
                    </li>
                    <li>
                        <a href="#" id="admin-logout"><i class="fas fa-sign-out-alt"></i> <span>Logout</span></a>
                    </li>
                </ul>
            </nav>
        </aside>
