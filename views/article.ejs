<%- include('partials/header-professional') %>

<%
    let displayCategory = 'UGC NET';
    if (article.tags && article.tags.length > 0) {
        displayCategory = article.tags[0];
    } else if (article.keywords) {
        displayCategory = Array.isArray(article.keywords)
            ? article.keywords[0]
            : article.keywords.split(',')[0];
    }
    let displayDate = new Date();
    if (article.datePublished) displayDate = new Date(article.datePublished);
    const dateStr = displayDate.toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' });
    let displayImage = article.featuredImage || '';
    const wordCount = (article.content || '').replace(/<[^>]+>/g, '').split(/\s+/).length;
    const readTime = Math.max(1, Math.round(wordCount / 200));
    const canonicalUrl = (process.env.FRONTEND_URL || 'https://saraswatiugcnet.com') + '/article/' + article.slug;
%>

<style>
.article-pg { background: var(--gray-50); min-height: 100vh; padding-bottom: 4rem; }

/* Reading progress bar */
.reading-progress {
  position: fixed; top: 0; left: 0; height: 3px; width: 0%;
  background: linear-gradient(90deg, var(--brand-blue), var(--brand-gold));
  z-index: 99998; transition: width 0.1s linear; pointer-events: none;
}

/* Hero */
.article-hero {
  background: linear-gradient(135deg, #0c4a6e 0%, #0369a1 60%, #0EA5E9 100%);
  padding: 2.5rem 0 3rem; position: relative; overflow: hidden;
}
.article-hero::after {
  content:''; position:absolute; right:-60px; top:-60px;
  width:300px; height:300px; border-radius:50%;
  background:radial-gradient(circle,rgba(255,255,255,0.06),transparent); pointer-events:none;
}
.article-hero-inner { position:relative; z-index:1; }

.article-breadcrumb {
  display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;
  font-size:0.8rem; color:rgba(255,255,255,0.65); margin-bottom:1.25rem;
}
.article-breadcrumb a { color:rgba(255,255,255,0.65); text-decoration:none; transition:color 0.2s; }
.article-breadcrumb a:hover { color:white; }
.article-breadcrumb i { font-size:0.6rem; opacity:0.5; }

.article-hero-tag {
  display:inline-flex; align-items:center; gap:0.4rem;
  background:rgba(255,255,255,0.15); backdrop-filter:blur(8px);
  color:white; font-size:0.74rem; font-weight:700;
  padding:0.28rem 0.85rem; border-radius:50px; margin-bottom:1rem;
  letter-spacing:0.04em; text-transform:uppercase;
}
.article-hero-title {
  font-family:var(--font-heading); font-size:clamp(1.45rem,4vw,2.4rem);
  font-weight:800; color:white; line-height:1.25; margin-bottom:1.25rem; max-width:780px;
}
.article-hero-meta { display:flex; flex-wrap:wrap; gap:1rem; align-items:center; }
.article-hero-meta-item {
  display:flex; align-items:center; gap:0.4rem;
  font-size:0.82rem; color:rgba(255,255,255,0.75);
}
.article-hero-meta-item i { font-size:0.75rem; }

/* Layout */
.article-layout {
  display:grid; grid-template-columns:1fr 290px;
  gap:1.75rem; align-items:start; margin-top:1.75rem;
}

/* Article card */
.article-card-wrap {
  background:white; border-radius:16px;
  box-shadow:0 4px 24px rgba(0,0,0,0.06); overflow:hidden;
}
.article-featured-img {
  width:100%; max-height:420px; object-fit:cover; display:block;
}
.article-card-body { padding:clamp(1.1rem,5vw,2.25rem); }

/* Typography */
.article-body { font-size:clamp(0.92rem,2.2vw,1.05rem); line-height:1.85; color:var(--gray-700); }
.article-body h2 {
  font-family:var(--font-heading); font-size:clamp(1.05rem,3vw,1.4rem); font-weight:800;
  color:var(--gray-900); margin:2rem 0 0.75rem;
  padding-left:0.85rem; border-left:4px solid var(--brand-blue);
}
.article-body h3 {
  font-family:var(--font-heading); font-size:clamp(0.95rem,2.5vw,1.18rem);
  font-weight:700; color:var(--gray-800); margin:1.5rem 0 0.6rem;
}
.article-body p { margin-bottom:1.1rem; }
.article-body ul, .article-body ol { padding-left:1.5rem; margin-bottom:1.1rem; }
.article-body li { margin-bottom:0.4rem; }
.article-body img { max-width:100%; border-radius:10px; margin:1rem 0; display:block; }
.article-body blockquote {
  border-left:4px solid var(--brand-gold); background:rgba(245,158,11,0.06);
  padding:1rem 1.25rem; margin:1.25rem 0; border-radius:0 10px 10px 0;
  font-style:italic; color:var(--gray-600);
}
.article-body table { width:100%; border-collapse:collapse; margin:1.25rem 0; font-size:0.9rem; overflow-x:auto; display:block; }
.article-body th { background:var(--brand-blue); color:white; padding:0.65rem 1rem; text-align:left; }
.article-body td { padding:0.6rem 1rem; border-bottom:1px solid var(--gray-100); }
.article-body tr:nth-child(even) td { background:var(--gray-50); }

/* Share */
.article-share {
  margin-top:2.25rem; padding-top:1.5rem;
  border-top:2px solid var(--gray-100);
  display:flex; align-items:center; gap:0.85rem; flex-wrap:wrap;
}
.article-share-label {
  font-family:var(--font-heading); font-size:0.8rem; font-weight:700;
  color:var(--gray-400); text-transform:uppercase; letter-spacing:0.06em;
}
.share-btns { display:flex; gap:0.45rem; flex-wrap:wrap; }
.share-btn {
  width:38px; height:38px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  color:white; text-decoration:none; font-size:0.88rem;
  transition:transform 0.2s, box-shadow 0.2s;
}
.share-btn:hover { transform:translateY(-2px); box-shadow:0 6px 14px rgba(0,0,0,0.18); }
.share-btn.fb { background:#1877f2; }
.share-btn.tw { background:#1da1f2; }
.share-btn.wa { background:#25d366; }
.share-btn.li { background:#0a66c2; }
.share-btn.copy { background:var(--gray-400); cursor:pointer; border:none; }
.share-btn.copy.copied { background:#10b981; }

/* Sidebar */
.article-sidebar {
  display:flex; flex-direction:column; gap:1.25rem;
  position:sticky; top:90px;
}
.sidebar-widget {
  background:white; border-radius:14px; padding:1.25rem;
  box-shadow:0 2px 12px rgba(0,0,0,0.05); border:1px solid var(--gray-100);
}
.sidebar-widget-title {
  font-family:var(--font-heading); font-size:0.72rem; font-weight:800;
  text-transform:uppercase; letter-spacing:0.08em; color:var(--gray-400); margin-bottom:1rem;
}
.toc-list { list-style:none; display:flex; flex-direction:column; gap:0.2rem; }
.toc-list a {
  display:block; font-size:0.81rem; color:var(--gray-600); text-decoration:none;
  padding:0.35rem 0.65rem; border-radius:7px; border-left:2px solid transparent; transition:all 0.15s; line-height:1.4;
}
.toc-list a:hover, .toc-list a.active {
  background:rgba(14,165,233,0.07); color:var(--brand-blue); border-left-color:var(--brand-blue);
}
.toc-list a.active { font-weight:600; }
.tags-cloud { display:flex; flex-wrap:wrap; gap:0.4rem; }
.tag-chip {
  font-size:0.75rem; font-weight:600; padding:0.28rem 0.75rem;
  background:var(--gray-100); color:var(--gray-600); border-radius:50px;
  text-decoration:none; transition:all 0.15s;
}
.tag-chip:hover { background:rgba(14,165,233,0.12); color:var(--brand-blue); }

/* CTA widget */
.cta-widget {
  background:linear-gradient(135deg,var(--brand-blue-d),var(--brand-blue));
  color:white; text-align:center; border-radius:14px; padding:1.5rem 1.25rem;
}
.cta-widget h4 { font-family:var(--font-heading); font-size:1rem; font-weight:800; color:white; margin-bottom:0.5rem; }
.cta-widget p { font-size:0.8rem; color:rgba(255,255,255,0.82); margin-bottom:1rem; line-height:1.5; }
.btn-cta {
  display:inline-flex; align-items:center; gap:0.4rem;
  background:var(--brand-gold); color:#1a1a2e; font-family:var(--font-heading);
  font-size:0.82rem; font-weight:800; padding:0.65rem 1.25rem; border-radius:10px;
  text-decoration:none; transition:all 0.2s;
}
.btn-cta:hover { background:var(--brand-gold-d); transform:translateY(-1px); color:#1a1a2e; }

/* ── RESPONSIVE ── */
@media (max-width:1024px) {
  .article-layout { grid-template-columns:1fr 250px; }
}
@media (max-width:860px) {
  .article-layout { grid-template-columns:1fr; }
  .article-sidebar { position:static; flex-direction:row; flex-wrap:wrap; }
  .cta-widget { flex:1; min-width:240px; }
  .sidebar-toc-widget, .sidebar-tags-widget { display:none; }
}
@media (max-width:576px) {
  .article-hero { padding:1.75rem 0 2.25rem; }
  .article-card-body { padding:1rem; }
  .article-body { font-size:0.93rem; line-height:1.8; }
  .article-body h2 { font-size:1.05rem; margin:1.5rem 0 0.6rem; }
  .article-body h3 { font-size:0.97rem; }
  .article-share { flex-direction:column; align-items:flex-start; gap:0.65rem; }
  .article-sidebar { flex-direction:column; }
}
</style>

<div class="reading-progress" id="reading-progress"></div>

<main class="article-pg">

  <div class="article-hero">
    <div class="container article-hero-inner">
      <nav class="article-breadcrumb" aria-label="Breadcrumb">
        <a href="/"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <a href="/articles">Articles</a>
        <i class="fas fa-chevron-right"></i>
        <span style="color:rgba(255,255,255,0.9);">Reading</span>
      </nav>
      <div class="article-hero-tag"><i class="fas fa-tag"></i> <%= displayCategory %></div>
      <h1 class="article-hero-title"><%= article.title %></h1>
      <div class="article-hero-meta">
        <span class="article-hero-meta-item"><i class="far fa-calendar-alt"></i> <%= dateStr %></span>
        <span class="article-hero-meta-item"><i class="far fa-user"></i> <%= article.author || 'Dr. Rajesh Mishra' %></span>
        <span class="article-hero-meta-item"><i class="fas fa-clock"></i> <%= readTime %> min read</span>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="article-layout">

      <!-- ARTICLE CONTENT -->
      <div>
        <div class="article-card-wrap">
          <% if (displayImage) { %>
            <img src="<%= displayImage %>" alt="<%= article.title %>" class="article-featured-img">
          <% } %>
          <div class="article-card-body">
            <div class="article-body" id="article-body">
              <%- article.content %>
            </div>
            <div class="article-share">
              <span class="article-share-label">Share</span>
              <div class="share-btns">
                <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(canonicalUrl) %>" target="_blank" rel="noopener" class="share-btn fb" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(canonicalUrl) %>&text=<%= encodeURIComponent(article.title) %>" target="_blank" rel="noopener" class="share-btn tw" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                <a href="https://wa.me/?text=<%= encodeURIComponent(article.title + ' ' + canonicalUrl) %>" target="_blank" rel="noopener" class="share-btn wa" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
                <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent(canonicalUrl) %>" target="_blank" rel="noopener" class="share-btn li" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                <button class="share-btn copy" id="copy-link-btn" aria-label="Copy link"><i class="fas fa-link"></i></button>
              </div>
            </div>
          </div>
        </div>
        <div style="margin-top:1.1rem;">
          <a href="/articles" style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.84rem;font-weight:600;color:var(--gray-500);text-decoration:none;">
            <i class="fas fa-arrow-left"></i> Back to All Articles
          </a>
        </div>
      </div>

      <!-- SIDEBAR -->
      <aside class="article-sidebar">
        <div class="cta-widget">
          <div style="font-size:2rem;margin-bottom:0.5rem;">📝</div>
          <h4>Test Your Knowledge</h4>
          <p>Take a UGC NET mock test and see how well-prepared you are.</p>
          <a href="/available-tests" class="btn-cta"><i class="fas fa-play-circle"></i> Take Free Test</a>
        </div>

        <div class="sidebar-widget sidebar-toc-widget" id="toc-widget">
          <div class="sidebar-widget-title">In this article</div>
          <ul class="toc-list" id="toc-list">
            <li><span style="font-size:0.8rem;color:var(--gray-400);">Loading…</span></li>
          </ul>
        </div>

        <% if (article.tags && article.tags.length > 0) { %>
        <div class="sidebar-widget sidebar-tags-widget">
          <div class="sidebar-widget-title">Tags</div>
          <div class="tags-cloud">
            <% article.tags.forEach(tag => { %><a href="/articles" class="tag-chip"><%= tag %></a><% }); %>
          </div>
        </div>
        <% } %>
      </aside>

    </div>
  </div>
</main>

<script>
(function(){
  // Reading progress
  const bar = document.getElementById('reading-progress');
  const body = document.getElementById('article-body');
  if (bar && body) {
    window.addEventListener('scroll', () => {
      const rect = body.getBoundingClientRect();
      const pct = Math.min(100, Math.max(0, (-rect.top / body.offsetHeight) * 100));
      bar.style.width = pct + '%';
    }, { passive: true });
  }

  // Table of contents
  const tocList = document.getElementById('toc-list');
  const tocWidget = document.getElementById('toc-widget');
  if (tocList && body) {
    const headings = Array.from(body.querySelectorAll('h2, h3'));
    if (headings.length > 1) {
      tocList.innerHTML = '';
      headings.forEach((h, i) => {
        if (!h.id) h.id = 'sec-' + i;
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        if (h.tagName === 'H3') a.style.paddingLeft = '1.1rem';
        a.addEventListener('click', e => { e.preventDefault(); h.scrollIntoView({ behavior:'smooth', block:'start' }); });
        li.appendChild(a); tocList.appendChild(li);
      });
      const links = tocList.querySelectorAll('a');
      const obs = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            links.forEach(l => l.classList.remove('active'));
            const a = tocList.querySelector('a[href="#' + entry.target.id + '"]');
            if (a) a.classList.add('active');
          }
        });
      }, { rootMargin:'-15% 0% -75% 0%' });
      headings.forEach(h => obs.observe(h));
    } else if (tocWidget) {
      tocWidget.style.display = 'none';
    }
  }

  // Copy link
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        copyBtn.classList.add('copied');
        copyBtn.innerHTML = '<i class="fas fa-check"></i>';
        setTimeout(() => { copyBtn.classList.remove('copied'); copyBtn.innerHTML = '<i class="fas fa-link"></i>'; }, 2000);
      });
    });
  }
})();
</script>

<%- include('partials/footer-professional') %>
